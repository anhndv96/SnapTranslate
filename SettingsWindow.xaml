<Window x:Class="SnapTranslate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt" 
        Height="360" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource MainGradientBrush}" 
            CornerRadius="20"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Direction="270" Color="#ef629f" Opacity="0.3"/>
        </Border.Effect>

        <Border Background="{StaticResource WhiteGlassBrush}"
                CornerRadius="18"
                Margin="2">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Content Panel -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Cài đặt hệ thống" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button Style="{StaticResource CloseButtonStyle}" ToolTip="Đóng" HorizontalAlignment="Right" Click="OnCancelClick" Margin="0,-5,-5,0">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="24" Height="24">
                                <Line X1="18" Y1="6" X2="6" Y2="18" Stroke="#5f6368" StrokeThickness="2"/>
                                <Line X1="6" Y1="6" X2="18" Y2="18" Stroke="#5f6368" StrokeThickness="2"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <!-- DeepSeek API Key -->
                    <TextBlock Text="DeepSeek API Key:" Margin="5,0,0,5" Foreground="#5f6368" FontWeight="Medium"/>
                    <TextBox x:Name="DeepSeekApiKeyTextBox" Height="35" Margin="0,0,0,12"
                             Padding="8,5" FontFamily="Consolas" FontSize="13" BorderBrush="#D1D1D1" BorderThickness="1" Background="#66FFFFFF" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Local LLM Endpoint -->
                    <TextBlock Text="Local LLM URL:" Margin="5,0,0,5" Foreground="#5f6368" FontWeight="Medium"/>
                    <TextBox x:Name="LocalLlmUrlTextBox" Height="35" Margin="0,0,0,12"
                             Padding="8,5" FontFamily="Consolas" FontSize="13" BorderBrush="#D1D1D1" BorderThickness="1" Background="#66FFFFFF" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Start with Windows CheckBox -->
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Khởi động cùng Windows" Margin="5,5,0,0"
                              Foreground="#5f6368" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <Button Content="Lưu" Width="90" Height="35" Click="OnSaveClick" Margin="0,0,10,0" Style="{StaticResource GradientButtonStyle}"/>
                    <Button Content="Hủy" Width="90" Height="35" Click="OnCancelClick" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
